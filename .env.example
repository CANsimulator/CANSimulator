# Environment Variables — CAN Simulator SaaS
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.

# ============================================================
# Supabase
# ============================================================
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# ============================================================
# Razorpay (Client-side public key only)
# ============================================================
VITE_RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXX
VITE_RAZORPAY_PLAN_PRO=plan_XXXX_pro
VITE_RAZORPAY_PLAN_TEAM=plan_XXXX_team

# ============================================================
# API (for Resend email edge functions)
# ============================================================
# If using Vercel: leave empty (routes auto-resolve from /api)
# If using a separate backend: set the base URL
VITE_API_BASE_URL=

# ============================================================
# Vercel Analytics (optional)
# ============================================================
# No key needed — @vercel/analytics automatically instruments when deployed
